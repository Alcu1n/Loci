{
  "version": 8,
  "name": "Loci AGPL Terrain Style",
  "sources": {
    "openfreemap": { "type": "vector", "url": "https://tiles.openfreemap.org/planet", "maxzoom": 14 }
  },
  "layers": [
    { "id": "loci-background", "type": "background", "paint": { "background-color": "#000000" } },
    { "id": "loci-landcover", "type": "fill", "source": "openfreemap", "source-layer": "landcover", "paint": { "fill-color": "#0E0E0E", "fill-opacity": 0.7 } },
    { "id": "loci-park", "type": "fill", "source": "openfreemap", "source-layer": "park", "paint": { "fill-color": "#171717" } },
    { "id": "loci-water", "type": "fill", "source": "openfreemap", "source-layer": "water", "paint": { "fill-color": "#0B0B0B" } },
    { "id": "loci-waterway", "type": "line", "source": "openfreemap", "source-layer": "waterway", "filter": ["match", ["geometry-type"], ["LineString", "MultiLineString"], true, false], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#0B0B0B", "line-width": ["interpolate", ["linear"], ["zoom"], 0, 0.2, 6, 0.34, 12, 0.8, 18, 2.4] } },
    { "id": "loci-aeroway", "type": "fill", "source": "openfreemap", "source-layer": "aeroway", "paint": { "fill-color": "#171717", "fill-opacity": 0.85 } },
    { "id": "loci-building", "type": "fill", "source": "openfreemap", "source-layer": "building", "minzoom": 8, "paint": { "fill-color": "#6F6F6F", "fill-opacity": 0.84 } },
    { "id": "loci-rail", "type": "line", "source": "openfreemap", "source-layer": "transportation", "filter": ["all", ["match", ["geometry-type"], ["LineString", "MultiLineString"], true, false], ["match", ["get", "class"], ["rail", "transit"], true, false]], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#FFFFFF", "line-width": ["interpolate", ["linear"], ["zoom"], 3, 0.4, 6, 0.7, 10, 1, 18, 1.5], "line-opacity": 0.65, "line-dasharray": [2, 1.6] } },
    { "id": "loci-road-overview-high", "type": "line", "source": "openfreemap", "source-layer": "transportation", "maxzoom": 11.8, "filter": ["match", ["get", "class"], ["primary", "primary_link", "secondary", "secondary_link", "motorway_link", "trunk", "trunk_link"], true, false], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#A0A0A0", "line-width": ["interpolate", ["linear"], ["zoom"], 0, 0.1, 4, 0.18, 8, 0.3, 11, 0.46], "line-opacity": ["interpolate", ["linear"], ["zoom"], 0, 0.66, 8, 0.76, 12, 0] } },
    { "id": "loci-road-overview-mid", "type": "line", "source": "openfreemap", "source-layer": "transportation", "maxzoom": 11.8, "filter": ["match", ["get", "class"], ["tertiary", "tertiary_link", "minor"], true, false], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#333333", "line-width": ["interpolate", ["linear"], ["zoom"], 0, 0.08, 4, 0.14, 8, 0.24, 11, 0.36], "line-opacity": ["interpolate", ["linear"], ["zoom"], 0, 0.46, 8, 0.56, 12, 0] } },
    { "id": "loci-road-overview-low", "type": "line", "source": "openfreemap", "source-layer": "transportation", "maxzoom": 11.8, "filter": ["match", ["get", "class"], ["residential", "living_street", "unclassified", "road", "street", "street_limited", "service"], true, false], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#242424", "line-width": ["interpolate", ["linear"], ["zoom"], 0, 0.06, 4, 0.1, 8, 0.18, 11, 0.3], "line-opacity": ["interpolate", ["linear"], ["zoom"], 0, 0.26, 8, 0.34, 12, 0] } },
    { "id": "loci-road-major-casing", "type": "line", "source": "openfreemap", "source-layer": "transportation", "filter": ["match", ["get", "class"], ["motorway"], true, false], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#575757", "line-width": ["interpolate", ["linear"], ["zoom"], 0, 0.5, 3, 0.72, 9, 1.52, 14, 2.83, 18, 4.55] } },
    { "id": "loci-road-high-casing", "type": "line", "source": "openfreemap", "source-layer": "transportation", "minzoom": 6, "filter": ["match", ["get", "class"], ["primary", "primary_link", "secondary", "secondary_link", "motorway_link", "trunk", "trunk_link"], true, false], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#575757", "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.67, 10, 1.16, 14, 2.15, 18, 3.92] } },
    { "id": "loci-road-mid-casing", "type": "line", "source": "openfreemap", "source-layer": "transportation", "minzoom": 6, "filter": ["match", ["get", "class"], ["tertiary", "tertiary_link", "minor"], true, false], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#575757", "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.39, 10, 0.71, 14, 1.38, 18, 2.7] } },
    { "id": "loci-road-major", "type": "line", "source": "openfreemap", "source-layer": "transportation", "filter": ["match", ["get", "class"], ["motorway"], true, false], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#E8E8E8", "line-width": ["interpolate", ["linear"], ["zoom"], 0, 0.36, 3, 0.52, 9, 1.1, 14, 2.05, 18, 3.3] } },
    { "id": "loci-road-high", "type": "line", "source": "openfreemap", "source-layer": "transportation", "minzoom": 6, "filter": ["match", ["get", "class"], ["primary", "primary_link", "secondary", "secondary_link", "motorway_link", "trunk", "trunk_link"], true, false], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#A0A0A0", "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.46, 10, 0.8, 14, 1.48, 18, 2.7] } },
    { "id": "loci-road-mid", "type": "line", "source": "openfreemap", "source-layer": "transportation", "minzoom": 6, "filter": ["match", ["get", "class"], ["tertiary", "tertiary_link", "minor"], true, false], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#333333", "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.34, 10, 0.62, 14, 1.2, 18, 2.35] } },
    { "id": "loci-road-low", "type": "line", "source": "openfreemap", "source-layer": "transportation", "minzoom": 6, "filter": ["match", ["get", "class"], ["residential", "living_street", "unclassified", "road", "street", "street_limited", "service"], true, false], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#242424", "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.24, 10, 0.44, 14, 0.84, 18, 1.65] } }
  ]
}
